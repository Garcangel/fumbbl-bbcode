[block width=50% bg=#fff]
Hello block
[/block]

[toggle label=Show block=example]
[block=hidden id=example bg=yellow]
Hidden content
[/block]
[/toggle]

[block=floatcontainer]
  [block=floatleft width=50% bg=#99f]
    Left column
  [/block]
  [block=floatright width=50% bg=#f99]
    Right column
  [/block]
[/block]

[table width=100%]
  [tr]
    [td width=50% bg=#eee]Cell 1[/td]
    [td width=50% bg=#ccc]Cell 2[/td]
  [/tr]
  [tr]
    [th colspan=2]Header row[/th]
  [/tr]
[/table]